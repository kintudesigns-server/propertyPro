datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPERADMIN
  OWNER        // Landlord/Property Owner
  INSPECTOR    // On-site Inspections
  TENANT       // Renter
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  password           String
  name               String?
  role               Role                 @default(TENANT)
  phone              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  accountStatus      String               @default("ACTIVE") // ACTIVE, PENDING_APPROVAL, SUSPENDED
  tenantStatus       String               @default("Pending Review")
  
  // Extended Tenant Profile
  avatar                 String?
  dob                    String?
  ssn                    String?
  employmentStatus       String?              @default("EMPLOYED")
  employer               String?
  position               String?
  annualIncome           Decimal?             @db.Decimal(10, 2)
  employmentStartDate    String?
  emergencyName          String?
  emergencyRelationship  String?
  emergencyPhone         String?
  emergencyEmail         String?
  creditScore            Int?
  targetMoveInDate       String?
  notes                  String?

  // Ledger Account for Owners
  bankName           String?
  accountNumber      String?
  accountName        String?
  balance            Decimal              @default(0.00) @db.Decimal(10, 2)

  // Stripe Saved Payment Method & Subscriptions
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  subscriptionStatus       String?              // active, past_due, canceled
  currentTierId            String?
  defaultPaymentMethodId   String?
  cardBrand                String?
  cardLast4                String?

  // Owner Limits
  approvalThreshold        Decimal              @default(200.00) @db.Decimal(10, 2)
  emergencyOverrideLimit   Decimal              @default(1500.00) @db.Decimal(10, 2)

  // Onboarding
  hasCompletedOnboarding   Boolean  @default(false)
  onboardingStep           Int      @default(0)

  // Relations
  ownedProperties      Property[]           @relation("OwnerProperties")
  leases               Lease[]              @relation("TenantLeases")
  maintenanceRequest   MaintenanceRequest[] @relation("TenantRequests")
  assignedInspections  MaintenanceRequest[] @relation("InspectorTasks")
  payoutRequests       PayoutRequest[]      @relation("OwnerPayouts")
  tenantPayoutRequests PayoutRequest[]      @relation("TenantPayouts")
  sentMessages         Message[]            @relation("SentMessages")
  receivedMessages     Message[]            @relation("ReceivedMessages")
  documents            Document[]           @relation("TenantDocuments")
  transactions         Transaction[]        @relation("TenantTransactions")
  notifications        Notification[]       @relation("UserNotifications")
  pricingTier          PricingTier?         @relation(fields: [currentTierId], references: [id])
  sentInvitations      TenantInvitation[]   @relation("InvitedByOwner")
  acceptedInvitations  TenantInvitation[]   @relation("AcceptedByTenant")
  passwordResetTokens  PasswordResetToken[]
  ownedVendors         ExternalVendor[]     @relation("OwnerVendors")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model OwnerApplication {
  id              String   @id @default(uuid())
  trackingId      String   @unique @default(uuid())
  name            String
  email           String
  phone           String
  website         String?
  entityType      String
  portfolioSize   String
  currentSoftware String?
  status          String   @default("PENDING")  // PENDING, UNDER_REVIEW, APPROVED, REJECTED
  adminNotes      String?
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedByAdminId String?
  createdUserId   String?   // User.id created after approval
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TenantInvitation {
  id              String   @id @default(uuid())
  token           String   @unique @default(uuid())
  tenantEmail     String
  tenantName      String
  unitId          String
  unit            Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  propertyId      String
  monthlyRent     Decimal  @db.Decimal(10, 2)
  leaseStartDate  DateTime
  status          String   @default("PENDING")  // PENDING, ACCEPTED, EXPIRED, CANCELLED
  invitedByOwnerId String
  invitedByOwner  User     @relation("InvitedByOwner", fields: [invitedByOwnerId], references: [id])
  acceptedByTenantId String?
  acceptedByTenant   User?  @relation("AcceptedByTenant", fields: [acceptedByTenantId], references: [id])
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PricingTier {
  id              String   @id @default(uuid())
  name            String
  description     String
  price           Float
  minUnits        Int
  maxUnits        Int
  features        String[]
  isCustom        Boolean  @default(false)
  isActive        Boolean  @default(true)
  stripeProductId String?
  stripePriceId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
}

model Property {
  id          String   @id @default(uuid())
  name        String
  address     String
  city        String
  country     String
  state       String   @default("")
  zip         String   @default("")
  coverPhoto  String?  // Cloudinary URL
  images      String[]
  amenities   String[]
  type        String   @default("Apartment")
  status      String   @default("AVAILABLE")
  approvalStatus String @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason String?
  yearBuilt   Int?
  description String?
  zoningType  String?
  parkingSpaces Int?
  createdAt   DateTime @default(now())
  
  // Scoped Ownership & Management
  ownerId     String
  owner       User     @relation("OwnerProperties", fields: [ownerId], references: [id])
  
  units       Unit[]
  documents   Document[]
  tours       Tour[]
}

model Unit {
  id           String               @id @default(uuid())
  name         String
  type         String?
  floor        Int?
  rentAmount   Decimal              @db.Decimal(10, 2)
  depositAmt   Decimal              @db.Decimal(10, 2)
  rooms        Int
  bathrooms    Int?
  sqFootage    Int
  amenities    String[]
  images       String[]
  maxOccupants Int      @default(1)
  status       String               @default("VACANT") // VACANT, OCCUPIED, MAINTENANCE
  leaseStructure String?            // NNN, Gross, etc.
  camCharges   Decimal?             @db.Decimal(10, 2)
  
  propertyId   String
  property     Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases       Lease[]
  maintenance  MaintenanceRequest[]
  applications Application[]
  tours        Tour[]
  invitations  TenantInvitation[]
}

model Lease {
  id          String    @id @default(uuid())
  unitId      String
  unit        Unit      @relation(fields: [unitId], references: [id])
  tenantId    String
  tenant      User      @relation("TenantLeases", fields: [tenantId], references: [id])
  startDate   DateTime
  endDate     DateTime
  monthlyRent Decimal   @db.Decimal(10, 2)
  status      String    @default("DRAFT") // DRAFT, PENDING_SIGNATURE, SIGNED, ACTIVE, NOTICE_GIVEN, TERMINATED, EXPIRED
  
  // Extended configuration fields
  rentDueDay           Int       @default(1)
  securityDeposit      Decimal?  @db.Decimal(10, 2)
  lateFeeAmount        Decimal?  @db.Decimal(10, 2)
  gracePeriodDays      Int       @default(5)
  lateFeeType          String    @default("FIXED") // FIXED, PERCENTAGE
  autoGenerateInvoices Boolean   @default(true)
  autoEmailInvoices    Boolean   @default(false)
  autoPayEnabled       Boolean   @default(false)
  
  // Early Termination Policies
  earlyTerminationFee     Decimal?  @default(0) @db.Decimal(10, 2)
  isProratedRefundAllowed Boolean   @default(false)

  
  // Phase 1: Security Deposits & Move-Out
  depositStatus        String    @default("HELD") // HELD, REFUNDED, PARTIALLY_REFUNDED, FULLY_DEDUCTED
  depositWithheldAmount Decimal   @default(0.00) @db.Decimal(10, 2)
  depositRefundAmount   Decimal   @default(0.00) @db.Decimal(10, 2)
  deductions           Json?     // Array of { amount: number, description: string, category: "DAMAGE"|"CLEANING"|"UNPAID_RENT"|"UNPAID_FEE"|"OTHER", photoUrl?: string }
  refundMethod         String?   // ORIGINAL, CHECK, OFFLINE, BANK_TRANSFER
  refundBankName       String?
  refundAccountName    String?
  refundAccountNumber  String?   // AES-256 encrypted
  refundRef            String?   // Stripe refund ID, check number, or wire reference

  // Move-Out Lifecycle
  // moveOutStatus: NONE | MOVE_OUT_REQUESTED | INSPECTION_SCHEDULED | INSPECTION_COMPLETED
  //                TENANT_ACCEPTED | TENANT_DISPUTED | DISPUTE_FINALIZED | COMPLETED | DEPOSIT_OVERDUE
  moveOutStatus        String    @default("NONE")
  moveOutRequestDate   DateTime?
  moveOutDate          DateTime?
  moveOutReason        String?
  otherReasonNote      String?   @db.Text  // Free-text when moveOutReason = "Other"
  forwardingAddress    String?   @db.Text
  isShortNotice        Boolean   @default(false)
  moveOutNoticeDays    Int       @default(30)
  depositReturnDays    Int       @default(21)
  moveOutInspectorId   String?
  inspectionDate       DateTime?
  inspectionNotes      String?   @db.Text
  inspectionPhotos     String[]
  tenantDisputeNote    String?   @db.Text
  tenantReviewedAt     DateTime?           // Timestamp of tenant accept or dispute action
  disputeCount         Int       @default(0)

  // Move-out Bypass & Dispute Resolution additions
  moveOutBypassReason         String?   @db.Text
  moveOutBypassAcknowledgedAt DateTime?
  disputeResolutionNotes      String?   @db.Text
  disputeResolvedAt           DateTime?

  // Preliminary inspection fields
  preliminaryInspectionDate   DateTime?
  preliminaryInspectorId       String?
  preliminaryInspectionStatus String    @default("NONE") // NONE, SCHEDULED, COMPLETED
  preliminaryDeductions       Json?
  preliminaryInspectionNotes  String?   @db.Text
  inspectorSignedAt            DateTime?
  preliminaryInspectorSignedAt DateTime?

  // Move-Out Key Return & Deposit Deadline Tracking
  actualMoveOutDate    DateTime?           // Set by owner when confirming key return
  keyReturnConfirmedAt DateTime?           // Timestamp of key return confirmation
  depositDueBy         DateTime?           // Legal deadline: actualMoveOutDate + depositReturnDays

  // Tenant Move-Out Acknowledgements (legal evidence)
  utilitiesAcknowledgedAt DateTime?        // When tenant confirmed utilities responsibility
  cleaningAcknowledgedAt  DateTime?        // When tenant agreed to move-out cleaning standards

  // Phase 3: Automated Renewals
  renewalNoticeDays    Int       @default(60) // Days before endDate to trigger renewal offer
  renewalStatus        String    @default("NOT_ELIGIBLE") // NOT_ELIGIBLE, PENDING_DECISION, RENEWED, NON_RENEWAL

  // Lease Signing & Move-In Gate
  signatureImageUrl    String?   @db.Text  // Base64 canvas signature drawn by tenant
  signedAt             DateTime?           // Timestamp of when tenant signed
  customTerms          String?   @db.Text  // Owner-added custom terms shown to tenant before signing
  moveInDate           DateTime?           // Planned physical move-in date (can differ from startDate)
  keysHandedOverAt     DateTime?           // When owner confirms keys were handed over → triggers ACTIVE
  
  invoices    Invoice[]
  payoutRequests PayoutRequest[]

  // Live Deposit Balance Tracking (mid-tenancy)
  depositPaidAt            DateTime?           // When tenant actually paid the deposit
  depositPaidAmount        Decimal?  @db.Decimal(10, 2) // Actual amount received
  depositBalance           Decimal   @default(0.00) @db.Decimal(10, 2) // Current remaining balance in escrow
  depositTransactionId     String?             // Transaction.id for the deposit payment record
  messages                 Message[]
}

model Invoice {
  id            String   @id @default(uuid())
  leaseId       String
  lease         Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(10, 2)
  dueDate       DateTime
  status        String   @default("UNPAID") // UNPAID, PAID, OVERDUE, VOID
  paymentMethod String?  // STRIPE, CASH, BANK_TRANSFER
  invoiceType   String   @default("RENT") // RENT, DEPOSIT, FEE, PRORATED, EARLY_TERMINATION, LATE_FEE
  
  // Financial Tracking (Phase 4 Monetization)
  processingFee Decimal? @db.Decimal(10, 2) // E.g. Stripe 2.9% fee passed to tenant
  adminFee      Decimal? @db.Decimal(10, 2) // Platform commission (e.g. 2%)
  netToOwner    Decimal? @db.Decimal(10, 2) // Final payout amount for owner
  grossPaid     Decimal? @db.Decimal(10, 2) // Total swiped (amount + processingFee)

  createdAt     DateTime @default(now())
  note          String?

  transactions  Transaction[]
}

model MaintenanceRequest {
  id           String   @id @default(uuid())
  unitId       String
  unit         Unit     @relation(fields: [unitId], references: [id])
  tenantId     String
  tenant       User     @relation("TenantRequests", fields: [tenantId], references: [id])
  title        String
  description  String
  category     String   @default("GENERAL") // PLUMBING, ELECTRICAL, APPLIANCE, GENERAL
  priority     String   @default("MEDIUM") // LOW, MEDIUM, HIGH, EMERGENCY
  status       String   @default("SUBMITTED") // SUBMITTED, ASSIGNED, RESOLVED, CLOSED
  photos       String[] // Cloudinary URLs
  
  // Local Inspector/Technician Assignment
  inspectorId   String?
  inspector     User?    @relation("InspectorTasks", fields: [inspectorId], references: [id])
  estimatedCost Decimal? @db.Decimal(10, 2)
  scheduledDate DateTime?
  
  // Phase 2: Real-World Maintenance Enhancements
  entryPermission     Boolean   @default(false)
  hasPets             String    @default("No")
  preferredTimes      String?
  diagnosisDate       DateTime?
  repairDate          DateTime?
  diagnosisPhotos     String[]
  repairPhotos        String[]
  receiptPhotos       String[]
  inspectorNotes      String?   @db.Text
  estimatedLabor      Decimal?  @db.Decimal(10, 2)
  estimatedMaterials  Decimal?  @db.Decimal(10, 2)
  finalLabor          Decimal?  @db.Decimal(10, 2)
  finalMaterials      Decimal?  @db.Decimal(10, 2)
  externalVendorName  String?
  
  // Real-world safeguards and accounting
  vendorReportedFault     Boolean   @default(false)
  ownerApprovedChargeback Boolean   @default(false)
  chargebackInvoiceId     String?
  vendorExpenseTransactionId String?
  isMoveOutInspection     Boolean   @default(false)
  vendorMagicToken        String?   @unique
  vendorTokenExpiresAt    DateTime?           // Token expires after job completion + 7 days
  externalVendorId        String?
  externalVendor          ExternalVendor? @relation(fields: [externalVendorId], references: [id])

  tenantRating            Int?
  tenantFeedback          String?   @db.Text
  tenantConfirmedSchedule Boolean   @default(false)
  rescheduleRequested     Boolean   @default(false)
  rescheduleReason        String?   @db.Text

  // Smart Liability Ruling (replaces simple ownerApprovedChargeback boolean)
  ownerChargebackDecision  String?   // "TENANT_FAULT" | "WEAR_AND_TEAR" | null (undecided)
  chargebackSource         String?   // "DEPOSIT" | "INVOICE" | "SPLIT"
  chargebackDepositAmount  Decimal?  @db.Decimal(10, 2) // Amount deducted from deposit
  chargebackInvoiceAmount  Decimal?  @db.Decimal(10, 2) // Amount billed as invoice
  
  isDuplicateSuspect      Boolean   @default(false)
  duplicateOfId           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  messages      Message[]
}

model PayoutRequest {
  id            String       @id @default(uuid())
  ownerId       String?
  owner         User?        @relation("OwnerPayouts", fields: [ownerId], references: [id])
  tenantId      String?
  tenant        User?        @relation("TenantPayouts", fields: [tenantId], references: [id])
  leaseId       String?
  lease         Lease?       @relation(fields: [leaseId], references: [id])
  amount        Decimal      @db.Decimal(10, 2)
  status        PayoutStatus @default(PENDING)
  bankName      String
  accountNumber String
  accountName   String
  proofUrl        String?      // Cloudinary receipt or verification link
  disbursedAt     DateTime?    // When the admin disbursed the payout
  refNumber       String?      // Bank transfer reference / check number
  rejectionReason String?      // Admin-provided reason when rejecting
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Application {
  id          String   @id @default(uuid())
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id])
  name        String
  email       String
  phone       String
  documents   String[] // Array of Cloudinary URLs (Legacy/General)
  idDocumentUrl  String?
  incomeProofUrl String?
  
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, LEASE_CREATED
  rejectionReason String? @db.Text
  
  // Real-world application preferences
  leaseDuration  Int       @default(12)
  moveInDate     DateTime?
  occupantsCount Int       @default(1)
  
  // Employment & Financials
  employerName   String?
  jobTitle       String?
  monthlyIncome  Decimal?  @db.Decimal(10, 2)
  
  // Co-Signer / Guarantor
  hasGuarantor    Boolean  @default(false)
  guarantorName   String?
  guarantorEmail  String?
  guarantorPhone  String?
  guarantorIncome Decimal? @db.Decimal(10, 2)
  
  // Landlord Reference & History
  prevLandlordName  String?
  prevLandlordPhone String?
  prevLandlordEmail String?
  reasonForMoving   String?
  
  // Pets & Vehicles
  petsCount      Int       @default(0)
  petDetails     String?
  vehicleInfo    String?

  // Emergency Contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Legal Consent
  backgroundCheckConsent Boolean @default(false)
  agreedToTerms          Boolean @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id             String   @id @default(uuid())
  senderId       String
  sender         User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId     String
  receiver       User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content        String
  isRead         Boolean  @default(false)
  conversationId String?  // Sort-joined user IDs e.g. "userId1_userId2"
  attachmentUrl  String?  // Document or photo attachment link
  messageType    String   @default("TEXT") // TEXT, SYSTEM, IMAGE, FILE
  
  // Phase 2 Context Relationships
  ticketId       String?
  ticket         MaintenanceRequest? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  leaseId        String?
  lease          Lease?              @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  
  createdAt      DateTime @default(now())
}

model Document {
  id          String   @id @default(uuid())
  name        String
  url         String
  category    String   // LEASE, PAYMENTS, MAINTENANCE, INSURANCE, IDENTIFICATION, NOTICES, GENERAL
  type        String   @default("Other") // Lease, Notice, Maintenance, Insurance, Identification, Income, Inspection, Receipt, Other
  description String?
  tags        String[]
  fileSize    String?
  uploadedAt  DateTime @default(now())
  tenantId    String
  tenant      User     @relation("TenantDocuments", fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}

model Transaction {
  id          String   @id @default(uuid())
  type        String   // INCOME, EXPENSE
  category    String   // RENT, FEE, DEPOSIT, MAINTENANCE, OTHER
  amount      Decimal  @db.Decimal(10, 2)
  reference   String?
  status      String   @default("COMPLETED") // COMPLETED, PENDING, FAILED
  createdAt   DateTime @default(now())
  tenantId    String?
  tenant      User?    @relation("TenantTransactions", fields: [tenantId], references: [id], onDelete: Cascade)
  
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  feeDeducted Decimal? @db.Decimal(10, 2)
}

model Notification {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  title           String
  message         String
  type            String   @default("SYSTEM")
  priority        String   @default("MEDIUM")
  isRead          Boolean  @default(false)
  relatedEntityId String?
  createdAt       DateTime @default(now())
}

enum TourType {
  IN_PERSON
  VIDEO_CALL
  SELF_GUIDED
}

enum TourStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Tour {
  id               String     @id @default(uuid())
  propertyId       String
  property         Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unitId           String?
  unit             Unit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  
  tenantName       String
  tenantEmail      String
  tenantPhone      String
  
  tourType         TourType   @default(IN_PERSON)
  scheduledAt      DateTime
  status           TourStatus @default(PENDING)
  
  feedbackRating   Int?
  feedbackComments String?
  
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model PlatformSettings {
  id              String   @id @default(uuid())
  adminFeePercent Decimal  @db.Decimal(5, 2) @default(2.00) // Default 2.00% admin commission
  updatedAt       DateTime @updatedAt
}

model ExternalVendor {
  id                  String               @id @default(uuid())
  name                String
  email               String
  phone               String
  specialty           String
  
  // Compliance & Rates
  w9OnFile            Boolean              @default(false)
  insuranceOnFile     Boolean              @default(false)
  baseCallOutFee      Float                @default(0.0)
  ownerId             String
  owner               User                 @relation("OwnerVendors", fields: [ownerId], references: [id])
  maintenanceRequests MaintenanceRequest[]
  
  // Direct Deposit Details
  bankName            String?
  routingNumber       String?
  accountNumber       String?
  
  createdAt           DateTime             @default(now())
}

model AuditLog {
  id           String   @id @default(uuid())
  entityType   String   // LEASE, INVOICE, MAINTENANCE, USER, PAYOUT, PROPERTY
  entityId     String
  action       String   // CREATED, UPDATED, DELETED, STATUS_CHANGED, SIGNED, ACTIVATED, TERMINATED
  actorId      String?  // User who performed the action (null = system/cron)
  actorRole    String?  // OWNER, TENANT, SUPERADMIN, SYSTEM
  oldValue     Json?    // Previous state (key fields only)
  newValue     Json?    // New state (key fields only)
  note         String?  // Human readable summary
  createdAt    DateTime @default(now())
}
